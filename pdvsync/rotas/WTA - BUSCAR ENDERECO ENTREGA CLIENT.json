{
	"tabela": {
		"nome": "PCINTEGRACAOROTASERVICO",
		"campos": [
			{
				"nome": "SOMENTEATUALIZARINTEGRACAOCORE",
				"valor": "N"
			},
			{
				"nome": "ID",
				"valor": "WTA - Buscar Endereco Entrega Client"
			},
			{
				"nome": "IDEMPRESAAPI",
				"valor": "WINTHOR-WTA"
			},
			{
				"nome": "SERVICO",
				"valor": "WTA - Buscar Endereco Entrega Client"
			},
			{
				"nome": "LAYOUTCOMUNICACAO",
				"valor": {
					"name": "WTA - Buscar Endereco Entrega Client",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{TOKEN}}"
							},
							{
								"key": "Accept",
								"value": "*/*"
							}
						],
						"url": {
							"raw": "{{URL_BASE}}/api/wholesale/v1/customer/deliveryAddress",
							"query": [
								{
									"key": "pageSize",
									"value": "{{PAGE_SIZE}}"
								},
								{
									"key": "page",
									"value": "{{PAGE}}"
								},
								{
									"key": "lastChange",
									"value": "{{DATAALTERACAO}}"
								}
							]
						}
					},
					"response": []
				}
			},
			{
				"nome": "LAYOUTTRANSFORMACAO",
				"valor": [
					{
						"operation": "modify-overwrite-beta",
						"spec": {
							"items": {
								"*": {
									"dadosTransformados": "=base64ToObject"
								}
							}
						}
					},
					{
						"operation": "modify-overwrite-beta",
						"spec": {
							"items": {
								"*": {
									"idExterno": "=concat('pdvsync-endereco-entrega-cliente-', @(1,lastChangeDate))",
									"idInterno": "=concat('', @(1,id))",
									"tipoIdInterno": "PDVSYNC-BUSCA-ENDERECO-ENTREGA-CLIENTE"
								}
							}
						}
					},
					{
						"operation": "shift",
						"spec": {
							"items": {
								"*": {
									"tipoIdInterno": "tipoIdInterno",
									"idExterno": "idExterno",
									"idInterno": "idInterno",
									"lastChangeDate": "items.[&1].DataAtualizacao",
									"zipCode": "items.[&1].cep",
									"city": "items.[&1].cidade",
									"state": "items.[&1].estado",
									"district": "items.[&1].bairro",
									"address": "items.[&1].endereco",
									"complement": "items.[&1].complemento",
									"number": "items.[&1].numero",
									"customerId": "items.[&1].idClienteRetaguarda",
									"id": "items.[&1].idRetaguarda",
									"active": {
										"true": {
											"#1": "items.[&3].situacao"
										},
										"*": {
											"#0": "items.[&3].situacao"
										}
									}
								}
							}
						}
					},
					{
						"operation": "modify-overwrite-beta",
						"spec": {
							"items": {
								"*": {
									"idRetaguarda": "=toString",
									"situacao": "=toInteger"
								}
							}
						}
					},
					{
						"operation": "default",
						"spec": {
							"_attr_access": "items",
							"items[]": {
								"*": {
									"idInquilino": "{{ID_INQUILINO}}",
									"idProprietario": "{{MASTER_ID_PROPRIETARIO}}",
									"loteOrigem": "{{LOTE_ORIGEM}}"
								}
							}
						}
					}
				]
			},
			{
				"nome": "ATIVO",
				"valor": "S"
			},
			{
				"nome": "AUTENTICADOR",
				"valor": "N"
			},
			{
				"nome": "DATASINCRONISMO",
				"valor": "14-NOV-23"
			},
			{
				"nome": "REFRESHTOKEN",
				"valor": ""
			},
			{
				"nome": "TIPOPROCESSO",
				"valor": "BUSCAR"
			}
		]
	}
}
